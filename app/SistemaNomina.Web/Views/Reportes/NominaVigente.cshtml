@model IEnumerable<SistemaNomina.Web.ViewModels.NominaVigenteViewModel>

@{
    ViewData["Title"] = "Nómina Vigente";
}

<h1>Nómina Vigente</h1>
<h5>Fecha de corte: @ViewBag.Fecha</h5>

<hr />

<!-- Filtros -->
<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <h5>Filtros</h5>
    </div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Departamento</label>
                <select name="deptNo" class="form-control">
                    <option value="">Todos los departamentos</option>
                    @foreach (var dept in ViewBag.Departamentos)
                    {
                        <option value="@dept.DeptNo" selected="@(dept.DeptNo == ViewBag.DeptNoSeleccionado ? true : false)">
                            @dept.DeptName
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Fecha de corte</label>
                <input type="date" name="fecha" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">Filtrar</button>

                <!-- Botón Exportar Excel -->
                <form asp-action="ExportarNominaExcel" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="deptNo" value="@ViewBag.DeptNoSeleccionado" />
                    <input type="hidden" name="fecha" value="@ViewBag.Fecha" />
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-file-excel"></i> Exportar a Excel
                    </button>
                </form>
        </form>
    </div>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Resultados -->
@if (!Model.Any())
{
    <div class="alert alert-warning">
        No hay resultados para mostrar con los filtros seleccionados.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Departamento</th>
                    <th>Empleado</th>
                    <th>Cédula</th>
                    <th>Cargo</th>
                    <th>Salario</th>
                    <th>Fecha Contratación</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Departamento</td>
                        <td>@item.Empleado</td>
                        <td>@item.Ci</td>
                        <td>@item.Cargo</td>
                        <td>@item.Salario.ToString("C2")</td>
                        <td>@item.FechaContratacion.ToShortDateString()</td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-secondary">
                <tr>
                    <td colspan="4" class="text-end"><strong>Totales:</strong></td>
                    <td><strong>@Model.Sum(m => m.Salario).ToString("C2")</strong></td>
                    <td><strong>@Model.Count() empleados</strong></td>
                </tr>
            </tfoot>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver a Reportes</a>
</div>