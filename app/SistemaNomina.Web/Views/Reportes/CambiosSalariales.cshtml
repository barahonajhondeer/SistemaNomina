@model IEnumerable<SistemaNomina.Web.ViewModels.CambioSalarialViewModel>

@{
    ViewData["Title"] = "Cambios Salariales";
}

<h1>Cambios Salariales</h1>
<h5>Período: @ViewBag.FechaInicio - @ViewBag.FechaFin</h5>

<hr />

<!-- Filtros -->
<div class="card mb-4">
    <div class="card-header bg-success text-white">
        <h5>Filtros</h5>
    </div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Fecha Inicio</label>
                <input type="date" name="fechaInicio" class="form-control" value="@DateTime.Today.AddDays(-30).ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Fecha Fin</label>
                <input type="date" name="fechaFin" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Departamento</label>
                <select name="deptNo" class="form-control">
                    <option value="">Todos los departamentos</option>
                    @foreach (var dept in ViewBag.Departamentos)
                    {
                        <option value="@dept.DeptNo" selected="@(dept.DeptNo == ViewBag.DeptNoSeleccionado ? true : false)">
                            @dept.DeptName
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-success">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<!-- Resultados -->
@if (!Model.Any())
{
    <div class="alert alert-warning">
        No hay cambios salariales en el período seleccionado.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Fecha</th>
                    <th>Empleado</th>
                    <th>Cédula</th>
                    <th>Salario Anterior</th>
                    <th>Salario Nuevo</th>
                    <th>Diferencia</th>
                    <th>Usuario</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FechaCambio.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.Empleado</td>
                        <td>@item.Ci</td>
                        <td class="text-end">@item.SalarioAnterior.ToString("C2")</td>
                        <td class="text-end">@item.SalarioNuevo.ToString("C2")</td>
                        <td class="text-end @(item.Diferencia >= 0 ? "text-success" : "text-danger")">
                            @item.Diferencia.ToString("C2")
                        </td>
                        <td>@item.Usuario</td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-secondary">
                <tr>
                    <td colspan="7" class="text-end">
                        <strong>Total de cambios: @Model.Count()</strong>
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver a Reportes</a>
</div>