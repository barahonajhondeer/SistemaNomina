@model IEnumerable<SistemaNomina.Web.ViewModels.EstructuraOrganizacionalViewModel>

@{
    ViewData["Title"] = "Estructura Organizacional";
}

<h1>Estructura Organizacional</h1>
<h5>Total: @ViewBag.TotalDepartamentos departamentos, @ViewBag.TotalEmpleados empleados</h5>

<hr />

<!-- Filtros -->
<div class="card mb-4">
    <div class="card-header bg-info text-white">
        <h5>Filtros</h5>
    </div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Departamento</label>
                <select name="deptNo" class="form-control">
                    <option value="">Todos los departamentos</option>
                    @foreach (var dept in Model)
                    {
                        <option value="@dept.DeptNo" selected="@(dept.DeptNo == ViewBag.DeptNoSeleccionado ? true : false)">
                            @dept.Departamento
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-info">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<!-- Resultados -->
@if (!Model.Any())
{
    <div class="alert alert-warning">
        No hay resultados para mostrar.
    </div>
}
else
{
    foreach (var dept in Model)
    {
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h4>@dept.Departamento (@dept.DeptNo)</h4>
                <h6>Gerente: @(dept.Gerente ?? "No asignado")</h6>
            </div>
            <div class="card-body">
                @if (!dept.Empleados.Any())
                {
                    <p class="text-muted">No hay empleados asignados a este departamento.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Empleado</th>
                                    <th>Cédula</th>
                                    <th>Cargo</th>
                                    <th>Salario</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var emp in dept.Empleados)
                                {
                                    <tr>
                                        <td>@emp.EmpNo</td>
                                        <td>@emp.Nombre</td>
                                        <td>@emp.Ci</td>
                                        <td>@emp.Cargo</td>
                                        <td>@emp.Salario.ToString("C2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="4" class="text-end"><strong>Total Empleados:</strong></td>
                                    <td><strong>@dept.TotalEmpleados</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver a Reportes</a>
</div>