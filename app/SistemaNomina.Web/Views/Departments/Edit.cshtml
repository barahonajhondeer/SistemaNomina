@model SistemaNomina.Web.Models.Department

@{
    ViewData["Title"] = "Editar Departamento";
}

<h1>Editar Departamento</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="dept_no" class="control-label">Código de Departamento</label>
                <input asp-for="dept_no" class="form-control" readonly />  <!-- READONLY porque es la clave -->
                <span asp-validation-for="dept_no" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="dept_name" class="control-label">Nombre del Departamento</label>
                <input asp-for="dept_name" class="form-control" />
                <span asp-validation-for="dept_name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}