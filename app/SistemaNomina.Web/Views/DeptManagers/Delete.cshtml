@model SistemaNomina.Web.Models.DeptManager

@{
    ViewData["Title"] = "Eliminar Gerente";
}

<h1>Eliminar Asignación de Gerente</h1>

<div class="alert alert-danger">
    <h3>¿Está seguro que desea eliminar esta asignación?</h3>
    <p>Esta acción no se puede deshacer.</p>
</div>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Departamento
        </dt>
        <dd class="col-sm-10">
            @Model.Department?.dept_name (@Model.dept_no)
        </dd>

        <dt class="col-sm-2">
            Gerente
        </dt>
        <dd class="col-sm-10">
            @Model.Employee?.first_name @Model.Employee?.last_name
        </dd>

        <dt class="col-sm-2">
            Fecha Inicio
        </dt>
        <dd class="col-sm-10">
            @Model.from_date.ToShortDateString()
        </dd>

        <dt class="col-sm-2">
            Fecha Fin
        </dt>
        <dd class="col-sm-10">
            @(Model.to_date?.ToShortDateString() ?? "Activo")
        </dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="dept_no" value="@Model.dept_no" />
        <input type="hidden" name="emp_no" value="@Model.emp_no" />
        <input type="hidden" name="from_date" value="@Model.from_date" />

        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>