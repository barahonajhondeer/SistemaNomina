@model IEnumerable<SistemaNomina.Web.ViewModels.DeptManagerViewModel>

@{
    ViewData["Title"] = "Gerentes de Departamento";
}

<h1>Gerentes de Departamento</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Asignar Nuevo Gerente</a>
</p>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" value="@ViewBag.SearchString"
               class="form-control" placeholder="Buscar por departamento o gerente..." />
        <button type="submit" class="btn btn-outline-secondary">Buscar</button>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Departamento</th>
            <th>Gerente</th>
            <th>Fecha Inicio</th>
            <th>Fecha Fin</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DepartamentoNombre (@item.dept_no)</td>
                <td>@item.GerenteNombre</td>
                <td>@item.from_date.ToShortDateString()</td>
                <td>@(item.to_date?.ToShortDateString() ?? "Activo")</td>
                <td>
                    @if (item.to_date == null)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit"
                       asp-route-dept_no="@item.dept_no"
                       asp-route-emp_no="@item.emp_no"
                       asp-route-from_date="@item.from_date.ToString("yyyy-MM-dd")"
                       class="btn btn-sm btn-warning">Editar</a>

                    <a asp-action="Delete"
                       asp-route-dept_no="@item.dept_no"
                       asp-route-emp_no="@item.emp_no"
                       asp-route-from_date="@item.from_date.ToString("yyyy-MM-dd")"
                       class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (ViewBag.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString">@i</a>
                </li>
            }
        </ul>
    </nav>
}