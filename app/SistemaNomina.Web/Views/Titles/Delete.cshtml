@model SistemaNomina.Web.Models.Title

@{
    ViewData["Title"] = "Eliminar Título";
}

<h1>Eliminar Título/Cargo</h1>

<div class="alert alert-danger">
    <h3>¿Está seguro que desea eliminar este título?</h3>
    <p>Esta acción no se puede deshacer.</p>
</div>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Empleado
        </dt>
        <dd class="col-sm-10">
            @Model.Employee?.first_name @Model.Employee?.last_name
        </dd>

        <dt class="col-sm-2">
            Título/Cargo
        </dt>
        <dd class="col-sm-10">
            @Model.title
        </dd>

        <dt class="col-sm-2">
            Fecha Inicio
        </dt>
        <dd class="col-sm-10">
            @Model.from_date.ToShortDateString()
        </dd>

        <dt class="col-sm-2">
            Fecha Fin
        </dt>
        <dd class="col-sm-10">
            @(Model.to_date?.ToShortDateString() ?? "Activo")
        </dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()

        <!-- Pasar los parámetros de la clave compuesta -->
        <input type="hidden" name="emp_no" value="@Model.emp_no" />
        <input type="hidden" name="title" value="@Model.title" />
        <input type="hidden" name="from_date" value="@Model.from_date" />

        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>